@model IEnumerable<FriendshipViewModel>

@{
    ViewData["Title"] = "Mis Amigos";
}

<div class="container mt-4">
    @if (TempData["SuccessFriendship"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessFriendship"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorFriendship"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorFriendship"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm border-0 mb-5">
        <div class="card-body">
            <h5 class="card-title fw-bold mb-3"><i class="bi bi-person-plus-fill text-primary"></i> Agregar nuevo amigo</h5>
            <form asp-controller="Friendship" asp-action="SendRequest" method="post" class="d-flex">
                <input type="text" name="receiverUsername" class="form-control form-control-lg me-2 bg-light border-0" placeholder="Escribe el nombre de usuario exacto..." required />
                <button type="submit" class="btn btn-primary px-4 fw-bold">Enviar Solicitud</button>
            </form>
        </div>
    </div>

    <h4 class="fw-bold mb-4"><i class="bi bi-people-fill text-success"></i> Mis Amigos (@Model.Count())</h4>

    @if (Model != null && Model.Any())
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var friend in Model)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm border-0 text-center py-4">
                        <div class="card-body">
                            <img src="@(string.IsNullOrEmpty(friend.OtherUserPhotoUrl) ? "https://via.placeholder.com/100" : friend.OtherUserPhotoUrl)"
                                 class="rounded-circle mb-3 img-thumbnail" style="width: 100px; height: 100px; object-fit: cover;" alt="Foto de amigo" />

                            <h5 class="card-title fw-bold mb-1">@friend.OtherUserName</h5>
                            <p class="text-muted small mb-3">@friend.MutualFriendsCount Amigos en común</p>

                            <form asp-controller="Friendship" asp-action="Delete" method="post">
                                <input type="hidden" name="id" value="@friend.Id" />
                                <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill px-3" onclick="return confirm('¿Estás seguro de que deseas eliminar a este amigo?');">
                                    <i class="bi bi-person-x-fill"></i> Eliminar
                                </button>
                            </form>
                            <hr class="my-2" />
                            <form asp-controller="Battleship" asp-action="CreateGame" method="post">
                                <input type="hidden" name="friendId" value="@friend.OtherUserId" />
                                <button type="submit" class="btn btn-warning btn-sm rounded-pill px-3 fw-bold w-100">
                                    <i class="bi bi-crosshair"></i> Jugar Battleship
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center text-muted mt-5 py-5 bg-white rounded shadow-sm">
            <i class="bi bi-emoji-frown fs-1"></i>
            <p class="mt-3 fs-5">Aún no tienes amigos en tu lista.</p>
            <p>¡Usa el buscador de arriba para empezar a conectar!</p>
        </div>
    }
</div>