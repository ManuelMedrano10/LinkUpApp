@model IEnumerable<PostViewModel>
@{
    ViewData["Title"] = "Feed de Publicaciones";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">

            <div class="card shadow-sm mb-4 border-0">
                <div class="card-body">
                    <form asp-controller="Home" asp-action="CreatePost" method="post" enctype="multipart/form-data">
                        <div class="mb-3">
                            <textarea name="Content" class="form-control border-0 bg-light" rows="3" placeholder="¿Qué estás pensando?" required></textarea>
                        </div>

                        <div class="d-flex justify-content-between align-items-center">
                            <div class="d-flex gap-2">
                                <label class="btn btn-outline-secondary btn-sm" style="cursor: pointer;">
                                    <i class="bi bi-image"></i> Foto
                                    <input type="file" name="File" accept="image/*" style="display: none;" />
                                </label>

                                <div class="input-group input-group-sm w-auto">
                                    <span class="input-group-text bg-white"><i class="bi bi-youtube text-danger"></i></span>
                                    <input type="url" name="YoutubeUrl" class="form-control" placeholder="Link de YouTube (Opcional)" />
                                </div>
                            </div>
                            <button type="submit" class="btn btn-primary px-4 fw-bold">Publicar</button>
                        </div>
                    </form>
                </div>
            </div>

            @if (Model != null && Model.Any())
            {
                foreach (var post in Model)
                {
                    <div class="card shadow-sm mb-4 border-0">
                        <div class="card-header bg-white d-flex align-items-center border-0 pt-3">
                            <img src="@(string.IsNullOrEmpty(post.UserProfilePicture) ? "https://via.placeholder.com/50" : post.UserProfilePicture)"
                                 class="rounded-circle me-2" style="width: 45px; height: 45px; object-fit: cover;" alt="Avatar" />
                            <div>
                                <h6 class="mb-0 fw-bold">@post.UserName</h6>
                                <small class="text-muted" style="font-size: 0.8rem;">@post.CreatedAt.ToString("dd MMM yyyy 'a las' hh:mm tt")</small>
                            </div>
                        </div>

                        <div class="card-body py-2">
                            <p class="card-text">@post.Content</p>

                            @if (!string.IsNullOrEmpty(post.ImageUrl))
                            {
                                <div class="text-center mt-3">
                                    <img src="@post.ImageUrl" class="img-fluid rounded" alt="Post Image" style="max-height: 400px; object-fit: contain;" />
                                </div>
                            }

                            @if (!string.IsNullOrEmpty(post.YoutubeUrl))
                            {
                                <div class="mt-3">
                                    <a href="@post.YoutubeUrl" target="_blank" class="btn btn-outline-danger btn-sm">
                                        <i class="bi bi-play-circle-fill"></i> Ver video en YouTube
                                    </a>
                                </div>
                            }
                        </div>

                        <div class="card-footer bg-white border-top-0 pb-0">
                            <div class="d-flex gap-3">
                                <form asp-controller="Home" asp-action="ToggleReaction" method="post" class="d-inline">
                                    <input type="hidden" name="postId" value="@post.Id" />
                                    <input type="hidden" name="isLike" value="true" />
                                    <button type="submit" class="btn btn-sm shadow-none @(post.CurrentUserReaction == true ? "text-primary" : "text-muted")">
                                        <i class="bi @(post.CurrentUserReaction == true ? "bi-hand-thumbs-up-fill" : "bi-hand-thumbs-up") fs-5"></i>
                                        @post.LikesCount
                                    </button>
                                </form>

                                <form asp-controller="Home" asp-action="ToggleReaction" method="post" class="d-inline">
                                    <input type="hidden" name="postId" value="@post.Id" />
                                    <input type="hidden" name="isLike" value="false" />
                                    <button type="submit" class="btn btn-sm shadow-none @(post.CurrentUserReaction == false ? "text-danger" : "text-muted")">
                                        <i class="bi @(post.CurrentUserReaction == false ? "bi-hand-thumbs-down-fill" : "bi-hand-thumbs-down") fs-5"></i>
                                        @post.DislikesCount
                                    </button>
                                </form>
                            </div>
                        </div>
                        <hr class="mx-3 my-2 text-muted">

                        <div class="card-body pt-0">
                            @if (post.Comments != null && post.Comments.Any())
                            {
                                <div class="mb-3 px-2">
                                    @foreach (var comment in post.Comments)
                                    {
                                        <div class="d-flex mb-2">
                                            <img src="@(string.IsNullOrEmpty(comment.UserImageUrl) ? "https://via.placeholder.com/35" : comment.UserImageUrl)"
                                                 class="rounded-circle me-2" style="width: 35px; height: 35px; object-fit: cover;" />
                                            <div class="bg-light rounded p-2 px-3 w-100">
                                                <h6 class="mb-0 fw-bold" style="font-size: 0.85rem;">@comment.UserName</h6>
                                                <p class="mb-0 text-dark" style="font-size: 0.9rem;">@comment.Content</p>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }

                            <form asp-controller="Home" asp-action="AddComment" method="post" class="d-flex mt-2">
                                <input type="hidden" name="PostId" value="@post.Id" />
                                <input type="text" name="Content" class="form-control form-control-sm rounded-pill me-2 bg-light border-0" placeholder="Escribe un comentario..." required />
                                <button type="submit" class="btn btn-primary btn-sm rounded-pill px-3"><i class="bi bi-send-fill"></i></button>
                            </form>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="text-center text-muted mt-5">
                    <i class="bi bi-inbox fs-1"></i>
                    <p class="mt-2">No hay publicaciones para mostrar. ¡Sé el primero en compartir algo!</p>
                </div>
            }
        </div>
    </div>
</div>
