@model IEnumerable<FriendshipViewModel>

@{
    ViewData["Title"] = "Solicitudes de Amistad";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold mb-0"><i class="bi bi-envelope-paper-fill text-warning"></i> Solicitudes Pendientes</h4>
        <span class="badge bg-danger rounded-pill fs-6">@Model.Count()</span>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="row row-cols-1 row-cols-md-2 g-4">
            @foreach (var request in Model)
            {
                <div class="col">
                    <div class="card shadow-sm border-0">
                        <div class="card-body d-flex align-items-center">
                            <img src="@(string.IsNullOrEmpty(request.OtherUserPhotoUrl) ? "https://via.placeholder.com/75" : request.OtherUserPhotoUrl)"
                                 class="rounded-circle me-3 img-thumbnail" style="width: 75px; height: 75px; object-fit: cover;" alt="Foto" />

                            <div class="flex-grow-1">
                                <h5 class="mb-0 fw-bold">@request.OtherUserName</h5>
                                <small class="text-muted">@request.MutualFriendsCount amigos en común</small>
                                <div class="text-muted" style="font-size: 0.8rem;">
                                    Hace @Math.Round((DateTime.Now - request.CreatedAt).TotalDays) días
                                </div>
                            </div>

                            <div class="d-flex flex-column gap-2 ms-2">
                                <form asp-controller="Friendship" asp-action="Accept" method="post" class="m-0">
                                    <input type="hidden" name="id" value="@request.Id" />
                                    <button type="submit" class="btn btn-success btn-sm w-100 rounded-pill fw-bold shadow-sm">
                                        <i class="bi bi-check-lg"></i> Aceptar
                                    </button>
                                </form>

                                <form asp-controller="Friendship" asp-action="Reject" method="post" class="m-0">
                                    <input type="hidden" name="id" value="@request.Id" />
                                    <button type="submit" class="btn btn-outline-danger btn-sm w-100 rounded-pill fw-bold">
                                        <i class="bi bi-x-lg"></i> Rechazar
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center text-muted mt-5 py-5 bg-white rounded shadow-sm">
            <i class="bi bi-envelope-check fs-1 text-success"></i>
            <p class="mt-3 fs-5">No tienes solicitudes pendientes.</p>
            <p>¡Estás al día!</p>
        </div>
    }
</div>